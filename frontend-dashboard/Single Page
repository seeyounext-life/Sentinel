<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sentinel | Physician Command Center</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-slate-900 text-slate-100 font-sans">

    <nav class="border-b border-slate-800 p-4 flex justify-between items-center bg-slate-900 sticky top-0 z-50">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-emerald-500 rounded-lg flex items-center justify-center">
                <i class="fas fa-shield-halved text-slate-900"></i>
            </div>
            <span class="text-xl font-bold tracking-tight">SENTINEL</span>
        </div>
        <div class="flex items-center gap-4 text-sm">
            <span class="text-slate-400"><i class="far fa-user-md mr-2"></i> Dr. Watcher (On-duty)</span>
            <div class="w-10 h-10 rounded-full bg-slate-800 border border-slate-700"></div>
        </div>
    </nav>

    <main class="p-6 max-w-7xl mx-auto">
        <div class="flex justify-between items-end mb-8">
            <div>
                <h1 class="text-3xl font-bold">Verified Dashboard</h1>
                <p class="text-slate-400 mt-1">Pending verification for Health Center Region 7</p>
            </div>
            
            <button onclick="alert('Success: 42 Green Cases Authorized!')" class="bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-3 rounded-xl font-bold transition-all flex items-center gap-2 shadow-lg shadow-emerald-900/20">
                <i class="fas fa-check-double"></i> Batch Authorize (42 Green Cases)
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <div class="bg-slate-800/50 border border-slate-700 p-4 rounded-2xl">
                <span class="text-slate-400 text-sm">Low Risk (Green)</span>
                <div class="text-2xl font-bold text-emerald-400">42 Cases</div>
            </div>
            <div class="bg-slate-800/50 border border-slate-700 p-4 rounded-2xl">
                <span class="text-slate-400 text-sm">Moderate Risk (Yellow)</span>
                <div class="text-2xl font-bold text-amber-400">12 Cases</div>
            </div>
            <div class="bg-slate-800/50 border border-slate-700 p-4 rounded-2xl">
                <span class="text-slate-400 text-sm">High Risk (Red)</span>
                <div class="text-2xl font-bold text-rose-500">3 Cases</div>
            </div>
        </div>

        <div class="bg-slate-800/30 border border-slate-800 rounded-3xl overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-800/50 text-slate-400 text-sm uppercase">
                        <th class="p-4 font-medium">Token ID</th>
                        <th class="p-4 font-medium">AI Evidence (Symptoms)</th>
                        <th class="p-4 font-medium">Confidence</th>
                        <th class="p-4 font-medium">Status</th>
                        <th class="p-4 font-medium text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    <tr class="hover:bg-slate-800/20 transition-colors">
                        <td class="p-4 font-mono text-emerald-400">#SN-4921</td>
                        <td class="p-4">Tonsillitis Indicators (Redness 82%)</td>
                        <td class="p-4">
                            <div class="w-24 bg-slate-700 h-2 rounded-full overflow-hidden">
                                <div class="bg-emerald-500 h-full w-[94%]"></div>
                            </div>
                            <span class="text-xs text-slate-500">94% Stable</span>
                        </td>
                        <td class="p-4"><span class="bg-emerald-500/10 text-emerald-500 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest border border-emerald-500/20">Green</span></td>
                        <td class="p-4 text-right"><button class="text-slate-400 hover:text-white">Review</button></td>
                    </tr>
                    
                    <tr class="bg-rose-500/5 hover:bg-rose-500/10 transition-colors">
                        <td class="p-4 font-mono text-rose-500 font-bold">#SN-8812</td>
                        <td class="p-4">Severe Wheezing + SpO2: 91%</td>
                        <td class="p-4 text-rose-400 italic text-sm font-medium">Immediate Review Required</td>
                        <td class="p-4"><span class="bg-rose-500 text-white px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest">RED</span></td>
                        <td class="p-4 text-right">
                            <button class="bg-rose-600 hover:bg-rose-500 text-white px-4 py-2 rounded-lg text-sm font-bold">OPEN EMERGENCY</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>
